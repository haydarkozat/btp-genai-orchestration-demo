# ---------------------------------------------------------------------------
# SAP AI Core / Generative AI Hub service key
# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in the values from your AI Core service key
# (BTP cockpit -> Instances and Subscriptions -> your AI Core instance -> service
# key). Leave it empty / delete `.env` to run in MOCK mode (no credentials, no
# network — the default).
#
# These exact variable names are the ones the SAP SDK (`gen_ai_hub`) reads from
# the environment to authenticate against AI Core via OAuth. Do NOT hand-roll the
# token exchange — the SDK does it for you when these are set.

AICORE_AUTH_URL=
AICORE_CLIENT_ID=
AICORE_CLIENT_SECRET=
AICORE_BASE_URL=
AICORE_RESOURCE_GROUP=default

# ---------------------------------------------------------------------------
# Application configuration (optional — sensible defaults shown)
# ---------------------------------------------------------------------------

# Force a backend instead of auto-detecting from the credentials above.
# One of: auto (default) | mock | live
BACKEND_MODE=auto

# Foundation model used by the orchestration service in LIVE mode.
# Set this to a model that is actually deployed/available in your GenAI Hub
# trial and resource group. Common trial-friendly choices: gpt-4o-mini, gpt-4o.
ORCHESTRATION_MODEL=gpt-4o-mini

# Optional: explicit orchestration deployment URL. Leave empty to let the SDK
# resolve it from your resource group.
AICORE_ORCHESTRATION_DEPLOYMENT_URL=

# Number of source chunks retrieved and injected as grounding context.
RAG_TOP_K=3

# Where `demo ingest` writes / `demo ask` reads the document index.
RAG_INDEX_PATH=.btp_rag/index.json

# Directory of source Markdown runbooks for `demo ingest`.
RAG_DOCS_DIR=data/runbooks
